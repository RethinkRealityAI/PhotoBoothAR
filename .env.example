# Which event this build renders (folder name under src/events/). Default: hope-gala
VITE_EVENT="hope-gala"

# Supabase — shared across events; data is partitioned by event_id
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Admin passcode gate for the hidden /admin studio
VITE_ADMIN_PASSCODE="changeme"

# Passcode gate for the public /upload page (guest bulk upload to the wall).
# Falls back to VITE_ADMIN_PASSCODE if left blank.
VITE_UPLOAD_PASSCODE=""

# AI asset generation moved server-side (Phase 4): the old VITE_GEMINI_API_KEY
# is gone — the key never ships to the browser anymore. Set GEMINI_API_KEY (and
# later HIGGSFIELD_API_KEY / HIGGSFIELD_API_URL / MESHY_API_KEY) as Supabase
# edge-function secrets instead:
#   supabase secrets set GEMINI_API_KEY=...

# Platform builds: default event slug used for bare legacy routes (e.g. /booth, /wall).
# Falls back to the neutral "demo" sandbox event — never point this at a real customer's event.
VITE_DEFAULT_EVENT=""

# Off by default. Set to "true" to surface the demo/sandbox event (see
# VITE_DEFAULT_EVENT above) on /host for orgs that haven't created an event of
# their own yet — a deliberate showcase toggle, not something to enable in
# production without thinking about it first.
VITE_SHOW_DEMO_EVENT=""
